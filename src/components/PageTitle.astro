---
import CopyMarkdown from './CopyMarkdown.astro';

/* Starlight 0.30+ exposes the page entry via Astro.locals.starlightRoute.
   The legacy `Astro.props.entry` is empty, so any code that reads from
   props silently produces the fallback chrome (generic pill, no icon). */
const route: any = (Astro as any).locals?.starlightRoute;
const entry = route?.entry;
const title = entry?.data?.title as string | undefined;
const description = entry?.data?.description as string | undefined;
const ask = entry?.data?.ask as string | undefined;

/* Auto-derive a hero lede from the first body paragraph when the
   frontmatter doesn't set `description`. We parse the raw markdown body
   because changes from remark plugins don't flow back into entry.data
   after content-collection schema validation. */
function deriveLedeFromBody(body: string | undefined): string | undefined {
  if (!body) return undefined;
  const lines = body.split('\n');
  let buf = '';
  let inFence = false;
  let inFrontmatter = false;
  let seenAny = false;

  for (let raw of lines) {
    const line = raw.trim();
    if (!seenAny && line === '---') { inFrontmatter = !inFrontmatter; continue; }
    if (inFrontmatter) continue;
    seenAny = true;

    // Skip fenced code blocks
    if (/^```/.test(line)) { inFence = !inFence; continue; }
    if (inFence) continue;

    // Skip blank lines (unless we've collected something — then flush)
    if (!line) {
      if (buf) break;
      continue;
    }
    // Skip headings
    if (/^#{1,6}\s/.test(line)) { if (buf) break; continue; }
    // Skip image / link-only / italic-only / blockquote / list lines
    if (/^!?\[.*\]\(.+\)\s*$/.test(line)) { if (buf) break; continue; }
    if (/^[*_].*[*_]\s*$/.test(line) && !buf) { if (buf) break; continue; }
    if (/^>/.test(line)) { if (buf) break; continue; }
    if (/^[-*+]\s|\d+\.\s/.test(line)) { if (buf) break; continue; }
    // Skip HTML block start (`<div`, `<table`, …)
    if (/^<\w/.test(line)) { if (buf) break; continue; }

    buf = buf ? `${buf} ${line}` : line;
    if (buf.length >= 280) break;
  }

  if (!buf || buf.length < 40) return undefined;
  const cleaned = buf
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/`([^`]+)`/g, '$1')
    .replace(/\*\*([^*]+)\*\*/g, '$1')
    .replace(/\*([^*]+)\*/g, '$1')
    .replace(/\s+/g, ' ')
    .trim();

  if (cleaned.length <= 220) return cleaned;
  const sentence = cleaned.match(/^([^.!?]+[.!?])/)?.[1];
  return sentence && sentence.length >= 60 && sentence.length <= 240
    ? sentence
    : cleaned.slice(0, 200).replace(/\s+\S*$/, '') + '…';
}

const lede = description && description.trim();

/* Page slug — `entry.id` is the canonical content-collection slug
   ("transformations/snowflake-plain"). Fall back to frontmatter or
   the route slug, then normalize. */
const rawId = (entry?.id as string | undefined) ?? '';
const frontmatterSlug = entry?.data?.slug as string | undefined;
const pageSlug = (frontmatterSlug || rawId || route?.slug || '')
  .replace(/^\//, '')
  .replace(/\/$/, '');

/* ---------- Auto-derive eyebrow pill from the top-level section ---------- */
const SECTION_LABELS: Record<string, string> = {
  'tutorial': 'Getting Started',
  'overview': 'Overview',
  'kai': 'Kai · AI Assistant',
  'flows': 'Flows',
  'data-apps': 'Data Apps',
  'components': 'Components',
  'catalog': 'Data Catalog',
  'storage': 'Storage',
  'transformations': 'Transformations',
  'workspace': 'Workspaces',
  'management': 'Management',
  'ai': 'AI Features',
  'external-integrations': 'External Integrations',
};
const topSegment = pageSlug.split('/')[0] ?? '';
const sectionLabel: string = (entry?.data as any)?.section
  ?? SECTION_LABELS[topSegment]
  ?? 'Keboola Docs';

/* ---------- Auto-derive a page icon (emoji) ---------- */
const ICON_MAP: Record<string, string> = {
  /* Section-level */
  'tutorial': '🧭',
  'overview': '🗺️',
  'kai': '✨',
  'flows': '🔀',
  'data-apps': '🚀',
  'components': '🧩',
  'catalog': '📚',
  'storage': '🗄️',
  'workspace': '🖥️',
  'management': '⚙️',
  'ai': '🧠',
  'external-integrations': '🔌',
  /* Specific pages */
  'transformations': '✨',
  'transformations/snowflake-plain': '❄️',
  'transformations/python-plain': '🐍',
  'transformations/r-plain': '📊',
  'transformations/dbt': '🔧',
  'transformations/bigquery': '🔷',
  'transformations/oracle': '🅾️',
  'transformations/mappings': '🔁',
  'transformations/variables': '📝',
  'transformations/code-patterns': '🎯',
  /* Tutorial sub-pages */
  'tutorial/load': '📥',
  'tutorial/manipulate': '✨',
  'tutorial/write': '📤',
  'tutorial/automate': '⏱️',
  'tutorial/ad-hoc': '🔬',
  'tutorial/branches': '🌿',
  'tutorial/onboarding': '🎓',
  /* Kai sub-pages */
  'kai/getting-started': '🧪',
  'kai/security-and-privacy': '🛡️',
  'kai/use-cases': '💡',
  'kai/best-practices': '📋',
  'kai/settings': '⚙️',
  'kai/python-client': '🐍',
  /* AI sub-pages */
  'ai/mcp-server': '🔌',
  /* Data Apps sub-pages */
  'data-apps/streamlit': '🐍',
  'data-apps/python-js': '⚡',
  'data-apps/authentication': '🔐',
  'data-apps/general-design-guide': '📐',
};
const pageIcon: string | undefined =
  (entry?.data as any)?.icon
  ?? ICON_MAP[pageSlug]
  ?? ICON_MAP[topSegment];

const lastUpdated = (entry?.data as any)?.lastUpdated
  ?? (route as any)?.lastUpdated;

/* Ask Kai is reached from the header and from the search modal — no per-page
   block is rendered. `ask` frontmatter kept available for future use. */
void ask;
---

<div class="b-pagehead">
  <div class="b-meta-row">
    <span class="b-pill">{sectionLabel}</span>
    {lastUpdated && (
      <span class="b-meta-text">
        Updated {new Date(lastUpdated).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
      </span>
    )}
  </div>

  <div class="page-title-row">
    <h1 id="_top" class="b-title">
      {pageIcon && <span class="b-title-icon" aria-hidden="true">{pageIcon}</span>}
      <span>{title}<slot /></span>
    </h1>
    <CopyMarkdown />
  </div>

  {lede && <p class="b-lede">{lede}</p>}
</div>
